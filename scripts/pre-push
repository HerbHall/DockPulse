#!/usr/bin/env bash
# Pre-push hook: runs the same checks as CI before allowing a push.
# Install: make hooks (or: cp scripts/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push)
set -euo pipefail

echo "==> pre-push: running CI checks..."

echo "--- go build"
cd backend && go build ./...
cd ..

echo "--- go test"
cd backend && go test ./...
cd ..

echo "--- golangci-lint"
cd backend && go run github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.1.6 run ./...
cd ..

echo "--- frontend typecheck"
cd ui && npx tsc --noEmit
cd ..

echo "--- frontend lint"
cd ui && npx eslint src/
cd ..

echo "--- markdownlint"
npx --yes markdownlint-cli2 "**/*.md" "#node_modules" "#*/node_modules"

echo "==> pre-push: all checks passed"
